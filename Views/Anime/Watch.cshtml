@model AnyComic.Models.Episodio

@{
    ViewData["Title"] = $"{ViewBag.AnimeTitulo} - {Model.NomeExibicao}";
    Layout = null; // No layout for immersive viewing experience

    var episodios = (List<AnyComic.Models.Episodio>)ViewBag.Episodios;
    var proximoEpisodio = ViewBag.ProximoEpisodio as AnyComic.Models.Episodio;
    var episodioAnterior = ViewBag.EpisodioAnterior as AnyComic.Models.Episodio;

    // Determine how to embed the episode video.
    var link = Model.LinkVideo?.Trim() ?? string.Empty;
    var isHttp = link.StartsWith("http://", StringComparison.OrdinalIgnoreCase)
        || link.StartsWith("https://", StringComparison.OrdinalIgnoreCase);
    var videoExtensions = new[] { ".mp4", ".webm", ".ogg", ".mov", ".m4v" };
    var isFile = videoExtensions.Any(ext => link.EndsWith(ext, StringComparison.OrdinalIgnoreCase))
        || link.StartsWith("/uploads/", StringComparison.OrdinalIgnoreCase);

    // Identify the provider so we can use a modern player (Plyr) for files,
    // YouTube and Vimeo, and fall back to a plain iframe for anything else.
    string? youtubeId = null;
    string? vimeoId = null;
    string embedUrl = link; // used only for the generic iframe fallback

    string ExtractAfter(string source, string token)
    {
        var i = source.IndexOf(token, StringComparison.OrdinalIgnoreCase);
        if (i < 0) return string.Empty;
        var rest = source.Substring(i + token.Length);
        var stop = rest.IndexOfAny(new[] { '?', '&', '/', '#' });
        return stop >= 0 ? rest.Substring(0, stop) : rest;
    }

    if (isHttp && !isFile)
    {
        if (link.Contains("youtube.com/watch", StringComparison.OrdinalIgnoreCase))
        {
            youtubeId = ExtractAfter(link, "v=");
        }
        else if (link.Contains("youtu.be/", StringComparison.OrdinalIgnoreCase))
        {
            youtubeId = ExtractAfter(link, "youtu.be/");
        }
        else if (link.Contains("youtube.com/embed/", StringComparison.OrdinalIgnoreCase))
        {
            youtubeId = ExtractAfter(link, "embed/");
        }
        else if (link.Contains("vimeo.com/", StringComparison.OrdinalIgnoreCase))
        {
            vimeoId = ExtractAfter(link, "vimeo.com/");
        }

        if (string.IsNullOrEmpty(youtubeId)) youtubeId = null;
        if (string.IsNullOrEmpty(vimeoId)) vimeoId = null;
    }

    // file | youtube | vimeo | iframe | none
    var playerKind = isFile ? "file"
        : youtubeId != null ? "youtube"
        : vimeoId != null ? "vimeo"
        : isHttp ? "iframe"
        : "none";

    var nextUrl = proximoEpisodio != null
        ? Url.Action("Watch", "Anime", new { id = ViewBag.AnimeId, episodioNumero = proximoEpisodio.NumeroEpisodio })
        : "";
    var prevUrl = episodioAnterior != null
        ? Url.Action("Watch", "Anime", new { id = ViewBag.AnimeId, episodioNumero = episodioAnterior.NumeroEpisodio })
        : "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"]</title>
    <link rel="icon" type="image/x-icon" href="~/icon.ico" />
    <link rel="stylesheet" href="https://cdn.plyr.io/3.7.8/plyr.css" />
    <style>
        :root {
            --primary-red: #ef2c2f;
            --bg-dark: #141414;
            --bg-darker: #0b0b0b;
            --bg-panel: #1c1c1c;
            --text-light: #ffffff;
            --text-muted: #9a9a9a;
            --border-soft: rgba(255, 255, 255, 0.08);
            --sidebar-w: 340px;
            --header-h: 56px;

            /* Plyr theme — match the app accent */
            --plyr-color-main: #ef2c2f;
            --plyr-video-background: #000;
            --plyr-menu-background: rgba(20, 20, 20, 0.95);
            --plyr-menu-color: #ffffff;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        html, body {
            background-color: var(--bg-dark);
            color: var(--text-light);
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
        }

        /* ===== Page shell ===== */
        .watch-page {
            display: flex;
            flex-direction: column;
            height: 100vh;
            height: 100dvh;
            overflow: hidden;
        }

        /* ===== Header ===== */
        .watch-header {
            height: var(--header-h);
            flex-shrink: 0;
            background-color: var(--bg-darker);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 16px;
            gap: 12px;
            border-bottom: 1px solid var(--border-soft);
            z-index: 30;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 12px;
            min-width: 0;
        }

        .header-titles { min-width: 0; line-height: 1.2; }

        .header-titles .anime-title {
            font-size: 15px;
            font-weight: 700;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .header-titles .episode-counter {
            font-size: 12px;
            color: var(--text-muted);
        }

        .header-right { display: flex; align-items: center; gap: 8px; }

        .icon-btn {
            background-color: transparent;
            border: 1px solid var(--border-soft);
            color: var(--text-light);
            height: 38px;
            min-width: 38px;
            padding: 0 12px;
            border-radius: 8px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: 13px;
            text-decoration: none;
            white-space: nowrap;
            transition: background-color .15s ease, border-color .15s ease;
        }

        .icon-btn:hover {
            background-color: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.25);
            color: var(--text-light);
        }

        /* ===== Body: player + sidebar ===== */
        .watch-body {
            flex: 1;
            min-height: 0;
            display: flex;
        }

        .watch-main {
            flex: 1;
            min-width: 0;
            display: flex;
            flex-direction: column;
            background-color: #000;
        }

        /* Stage fits the largest 16:9 box inside the available space (both axes) */
        .player-stage {
            flex: 1;
            min-height: 0;
            display: flex;
            background-color: #000;
            overflow: hidden;
            container-type: size;
        }

        .player-wrapper {
            margin: auto;
            aspect-ratio: 16 / 9;
            width: 100%;
            width: min(100%, calc(100cqh * 16 / 9));
            background-color: #000;
            position: relative;
        }

        /* Raw iframe fallback (no Plyr) fills the wrapper */
        .player-wrapper > iframe,
        .player-wrapper > video {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            border: 0;
            background-color: #000;
        }

        /* Plyr fills the 16:9 wrapper (already sized to fit the viewport).
           Width drives the size; Plyr's own 16:9 ratio sets the height,
           which matches the wrapper exactly. */
        .player-wrapper .plyr {
            width: 100%;
            margin: auto;
        }

        .player-wrapper .plyr__poster { background-size: cover; }

        .player-empty {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
            color: var(--text-muted);
            text-align: center;
            padding: 20px;
        }

        /* ===== Control bar under player ===== */
        .watch-controls {
            flex-shrink: 0;
            background-color: var(--bg-darker);
            border-top: 1px solid var(--border-soft);
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
        }

        .episode-meta {
            flex: 1;
            min-width: 0;
            text-align: center;
        }

        .episode-meta .ep-title {
            font-size: 15px;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .episode-meta .ep-date {
            font-size: 12px;
            color: var(--text-muted);
        }

        .nav-btn {
            background-color: transparent;
            border: 1px solid var(--border-soft);
            color: var(--text-light);
            height: 40px;
            padding: 0 16px;
            border-radius: 8px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            white-space: nowrap;
            transition: background-color .15s ease, border-color .15s ease;
        }

        .nav-btn:hover {
            background-color: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.25);
            color: var(--text-light);
        }

        .nav-btn-primary {
            background-color: var(--primary-red);
            border-color: var(--primary-red);
        }

        .nav-btn-primary:hover { background-color: #d61f22; border-color: #d61f22; }

        .nav-btn.disabled { opacity: .3; pointer-events: none; }

        /* ===== Episode sidebar ===== */
        .episode-sidebar {
            width: var(--sidebar-w);
            flex-shrink: 0;
            background-color: var(--bg-panel);
            border-left: 1px solid var(--border-soft);
            display: flex;
            flex-direction: column;
            min-height: 0;
        }

        .sidebar-header {
            flex-shrink: 0;
            padding: 14px 16px;
            font-size: 14px;
            font-weight: 700;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--border-soft);
        }

        .sidebar-header .count {
            font-size: 12px;
            font-weight: 500;
            color: var(--text-muted);
        }

        .episode-list {
            overflow-y: auto;
            flex: 1;
            min-height: 0;
            padding: 8px;
        }

        .episode-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 12px;
            border-radius: 8px;
            text-decoration: none;
            color: var(--text-light);
            transition: background-color .15s ease;
        }

        .episode-item:hover { background-color: rgba(255, 255, 255, 0.06); }

        .episode-item.active {
            background-color: rgba(239, 44, 47, 0.14);
            box-shadow: inset 3px 0 0 var(--primary-red);
        }

        .ep-num {
            flex-shrink: 0;
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background-color: rgba(255, 255, 255, 0.07);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            font-weight: 700;
            color: var(--text-light);
        }

        .episode-item.active .ep-num {
            background-color: var(--primary-red);
            color: #fff;
        }

        .ep-body { min-width: 0; flex: 1; }

        .ep-body .ep-name {
            font-size: 13px;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .ep-body .ep-sub {
            font-size: 11px;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .now-playing {
            color: var(--primary-red);
            font-weight: 700;
        }

        /* Theater mode (desktop): hide sidebar to give video full width */
        .watch-page.theater .episode-sidebar { display: none; }

        /* Hide the mobile-only "episodes" toggle on desktop */
        .episodes-toggle { display: none; }

        /* ===== Responsive: stack on tablet / mobile ===== */
        @@media (max-width: 1024px) {
            .watch-page {
                height: auto;
                min-height: 100dvh;
                overflow: visible;
            }

            .watch-header {
                position: sticky;
                top: 0;
            }

            .watch-body { flex-direction: column; }

            .watch-main { flex: none; }

            /* Player sticks below the header while the list scrolls */
            .player-stage {
                position: sticky;
                top: var(--header-h);
                z-index: 20;
                container-type: normal;
                display: block;
                background-color: #000;
            }

            .player-wrapper {
                width: 100%;
                max-width: 100%;
                aspect-ratio: 16 / 9;
            }

            .episode-sidebar {
                width: 100%;
                border-left: none;
                border-top: 1px solid var(--border-soft);
            }

            .episode-list { overflow-y: visible; }

            /* Theater toggle is desktop-only */
            .theater-toggle { display: none; }
        }

        @@media (max-width: 560px) {
            .header-titles .anime-title { font-size: 14px; }
            .btn-text { display: none; }
            .nav-btn { padding: 0 12px; }
            .icon-btn { padding: 0 10px; }
            .watch-controls { padding: 10px 12px; gap: 8px; }
        }

        .episode-list::-webkit-scrollbar { width: 8px; }
        .episode-list::-webkit-scrollbar-thumb {
            background-color: rgba(255, 255, 255, 0.15);
            border-radius: 4px;
        }
    </style>
</head>
<body>
    <div class="watch-page" id="watchPage">
        <!-- Header -->
        <header class="watch-header">
            <div class="header-left">
                <a href="@Url.Action("Details", "Anime", new { id = ViewBag.AnimeId })" class="icon-btn" title="Back to details">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8z"/>
                    </svg>
                </a>
                <div class="header-titles">
                    <div class="anime-title">@ViewBag.AnimeTitulo</div>
                    <div class="episode-counter">@Model.NomeExibicao &middot; @ViewBag.TotalEpisodios episodes</div>
                </div>
            </div>
            <div class="header-right">
                <button type="button" class="icon-btn theater-toggle" id="theaterToggle" onclick="toggleTheater()" title="Theater mode (T)">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm15 0a1 1 0 0 0-1-1H2a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4z"/>
                    </svg>
                    <span class="btn-text">Theater</span>
                </button>
                <button type="button" class="icon-btn episodes-toggle" onclick="scrollToList()" title="Episodes">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M5 11.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zm-3 8a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm0-4a1 1 0 1 1 0-2 1 1 0 0 1 0 2zm0-4a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/>
                    </svg>
                </button>
            </div>
        </header>

        <!-- Body -->
        <div class="watch-body">
            <main class="watch-main">
                <div class="player-stage">
                    <div class="player-wrapper">
                        @if (playerKind == "file")
                        {
                            <video id="player" playsinline controls controlslist="nodownload">
                                <source src="@link" />
                                Your browser does not support the video tag.
                            </video>
                        }
                        else if (playerKind == "youtube")
                        {
                            <div id="player" data-plyr-provider="youtube" data-plyr-embed-id="@youtubeId"></div>
                        }
                        else if (playerKind == "vimeo")
                        {
                            <div id="player" data-plyr-provider="vimeo" data-plyr-embed-id="@vimeoId"></div>
                        }
                        else if (playerKind == "iframe")
                        {
                            <iframe src="@embedUrl" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
                        }
                        else
                        {
                            <div class="player-empty">
                                <div>
                                    <p>This episode has no playable video source.</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="watch-controls">
                    @if (episodioAnterior != null)
                    {
                        <a href="@prevUrl" class="nav-btn">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z"/>
                            </svg>
                            <span class="btn-text">Previous</span>
                        </a>
                    }
                    else
                    {
                        <span class="nav-btn disabled">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z"/>
                            </svg>
                            <span class="btn-text">Previous</span>
                        </span>
                    }

                    <div class="episode-meta">
                        <div class="ep-title">@Model.NomeExibicao</div>
                        <div class="ep-date">Released @Model.DataLancamento.ToString("MMM dd, yyyy")</div>
                    </div>

                    @if (proximoEpisodio != null)
                    {
                        <a href="@nextUrl" class="nav-btn nav-btn-primary">
                            <span class="btn-text">Next</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                            </svg>
                        </a>
                    }
                    else
                    {
                        <span class="nav-btn disabled">
                            <span class="btn-text">Next</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"/>
                            </svg>
                        </span>
                    }
                </div>
            </main>

            <!-- Episode list sidebar -->
            <aside class="episode-sidebar" id="episodeSidebar">
                <div class="sidebar-header">
                    <span>Episodes</span>
                    <span class="count">@ViewBag.TotalEpisodios total</span>
                </div>
                <div class="episode-list" id="episodeList">
                    @foreach (var ep in episodios)
                    {
                        var isActive = ep.Id == Model.Id;
                        <a href="@Url.Action("Watch", "Anime", new { id = ViewBag.AnimeId, episodioNumero = ep.NumeroEpisodio })"
                           class="episode-item @(isActive ? "active" : "")"
                           id="@(isActive ? "activeEpisode" : null)">
                            <div class="ep-num">@ep.NumeroEpisodio</div>
                            <div class="ep-body">
                                <div class="ep-name">@ep.NomeExibicao</div>
                                <div class="ep-sub">
                                    @if (isActive)
                                    {
                                        <span class="now-playing">● Now playing</span>
                                    }
                                    else
                                    {
                                        <span>@ep.DataLancamento.ToString("MMM dd, yyyy")</span>
                                    }
                                </div>
                            </div>
                        </a>
                    }
                </div>
            </aside>
        </div>
    </div>

    <script src="https://cdn.plyr.io/3.7.8/plyr.polyfilled.js"></script>
    <script>
        const animeId = @ViewBag.AnimeId;
        const prevUrl = '@Html.Raw(prevUrl)';
        const nextUrl = '@Html.Raw(nextUrl)';
        const detailsUrl = '@Url.Action("Details", "Anime", new { id = ViewBag.AnimeId })';

        // ----- Modern player (Plyr) for files, YouTube and Vimeo -----
        let player = null;
        const playerEl = document.getElementById('player');
        if (playerEl && window.Plyr) {
            player = new Plyr(playerEl, {
                ratio: '16:9',
                autoplay: true,
                keyboard: { focused: true, global: true },
                clickToPlay: true,
                controls: [
                    'play-large', 'rewind', 'play', 'fast-forward',
                    'progress', 'current-time', 'duration',
                    'mute', 'volume', 'captions', 'settings',
                    'pip', 'airplay', 'fullscreen'
                ],
                settings: ['captions', 'quality', 'speed', 'loop'],
                speed: { selected: 1, options: [0.5, 0.75, 1, 1.25, 1.5, 1.75, 2] },
                seekTime: 10,
                tooltips: { controls: true, seek: true },
                youtube: { noCookie: true, rel: 0, modestbranding: 1, playsinline: 1 },
                vimeo: { byline: false, portrait: false, title: false }
            });

            // Auto-advance to the next episode when playback ends
            if (nextUrl) {
                player.on('ended', function () { window.location.href = nextUrl; });
            }
        }
        const hasPlayer = !!player;

        // ----- Theater mode (desktop) -----
        function toggleTheater() {
            const page = document.getElementById('watchPage');
            page.classList.toggle('theater');
            try { localStorage.setItem('anime_theater', page.classList.contains('theater') ? '1' : '0'); } catch (e) {}
        }
        // Restore preference
        try {
            if (localStorage.getItem('anime_theater') === '1') {
                document.getElementById('watchPage').classList.add('theater');
            }
        } catch (e) {}

        // ----- Mobile: jump to episode list -----
        function scrollToList() {
            document.getElementById('episodeSidebar').scrollIntoView({ behavior: 'smooth' });
        }

        // ----- Keep the active episode visible in the sidebar -----
        (function () {
            const active = document.getElementById('activeEpisode');
            if (active && window.matchMedia('(min-width: 1025px)').matches) {
                active.scrollIntoView({ block: 'center' });
            }
        })();

        // ----- Keyboard shortcuts (episode navigation) -----
        // When a Plyr player is active, the arrow keys are left to the player
        // (seek). Use N / P for episode navigation in that case.
        document.addEventListener('keydown', function (e) {
            // Ignore when typing in a field
            if (e.target && /^(INPUT|TEXTAREA|SELECT)$/.test(e.target.tagName)) return;

            switch (e.key) {
                case 'ArrowLeft':
                    if (!hasPlayer && prevUrl) { window.location.href = prevUrl; }
                    break;
                case 'ArrowRight':
                    if (!hasPlayer && nextUrl) { window.location.href = nextUrl; }
                    break;
                case 'n': case 'N':
                    if (nextUrl) window.location.href = nextUrl;
                    break;
                case 'p': case 'P':
                    if (prevUrl) window.location.href = prevUrl;
                    break;
                case 't': case 'T':
                    if (window.matchMedia('(min-width: 1025px)').matches) toggleTheater();
                    break;
                case 'Escape':
                    window.location.href = detailsUrl;
                    break;
            }
        });
    </script>
</body>
</html>
