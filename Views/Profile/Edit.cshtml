@model AnyComic.Models.ViewModels.EditarPerfilViewModel
@{
    ViewData["Title"] = "Editar Perfil";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />

<style>
    .edit-profile-wrap {
        max-width: 680px;
        margin: 36px auto 60px;
        padding: 0 16px;
    }
    .edit-profile-title {
        font-size: 20px;
        font-weight: 700;
        color: white;
        margin-bottom: 28px;
    }

    /* Banner upload */
    .banner-upload-zone {
        width: 100%;
        height: 160px;
        border-radius: 12px;
        border: 2px dashed rgba(255,255,255,.15);
        background: #1a1a1a;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        overflow: hidden;
        position: relative;
        transition: border-color .2s;
        margin-bottom: 8px;
    }
    .banner-upload-zone:hover { border-color: #e63946; }
    .banner-upload-zone .upload-hint {
        text-align: center;
        color: rgba(255,255,255,.3);
        pointer-events: none;
    }
    .banner-upload-zone .upload-hint svg { display: block; margin: 0 auto 8px; }
    .banner-upload-zone .upload-hint p { font-size: 13px; margin: 0; }
    .banner-upload-zone img.preview {
        position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    }
    .banner-re-crop {
        position: absolute;
        bottom: 8px; right: 8px;
        background: rgba(0,0,0,.65);
        border: 1px solid rgba(255,255,255,.2);
        color: white;
        font-size: 11px;
        padding: 4px 10px;
        border-radius: 6px;
        cursor: pointer;
        backdrop-filter: blur(4px);
        display: none;
    }
    .banner-upload-zone.has-banner .banner-re-crop { display: block; }

    /* Avatar upload */
    .avatar-row { display: flex; align-items: center; gap: 20px; margin-bottom: 24px; }
    .avatar-upload-zone {
        width: 88px; height: 88px;
        border-radius: 50%;
        border: 2px dashed rgba(255,255,255,.2);
        background: #2a2a2a;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; overflow: hidden; position: relative;
        flex-shrink: 0; transition: border-color .2s;
    }
    .avatar-upload-zone:hover { border-color: #e63946; }
    .avatar-upload-zone img.preview {
        position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    }
    .avatar-upload-zone .avatar-placeholder {
        font-size: 28px; font-weight: 700; color: rgba(255,255,255,.35); pointer-events: none;
    }
    .avatar-upload-zone.has-image .avatar-placeholder { display: none; }
    .avatar-info { color: rgba(255,255,255,.4); font-size: 12px; line-height: 1.6; }
    .avatar-info strong { color: rgba(255,255,255,.7); display: block; font-size: 14px; margin-bottom: 2px; }

    /* Form elements */
    .form-group { margin-bottom: 22px; }
    .form-label { display: block; font-size: 13px; font-weight: 600; color: rgba(255,255,255,.55); margin-bottom: 8px; }
    .form-control-dark {
        width: 100%;
        background: #1a1a1a;
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 8px;
        color: white;
        padding: 11px 14px;
        font-size: 14px;
        resize: vertical;
        font-family: inherit;
        transition: border-color .2s;
    }
    .form-control-dark:focus { outline: none; border-color: #e63946; }
    .form-control-dark::placeholder { color: rgba(255,255,255,.2); }
    textarea.form-control-dark { min-height: 110px; }
    .char-count { font-size: 11px; color: rgba(255,255,255,.25); text-align: right; margin-top: 4px; }
    .char-count.near { color: #e69346; }
    .char-count.over  { color: #e63946; }
    .field-error { color: #e63946; font-size: 12px; margin-top: 4px; }

    /* Action buttons */
    .btn-row { display: flex; gap: 12px; justify-content: flex-end; margin-top: 32px; }
    .btn-save {
        background: #e63946; color: white; border: none;
        padding: 10px 28px; border-radius: 8px; font-size: 14px; font-weight: 600;
        cursor: pointer; transition: background .2s;
    }
    .btn-save:hover { background: #c5303b; }
    .btn-cancel {
        background: transparent; color: rgba(255,255,255,.5);
        border: 1px solid rgba(255,255,255,.15);
        padding: 10px 20px; border-radius: 8px; font-size: 14px;
        text-decoration: none; transition: border-color .2s, color .2s;
    }
    .btn-cancel:hover { border-color: rgba(255,255,255,.35); color: rgba(255,255,255,.8); }

    input[type=file] { display: none; }

    /* ── Crop modal ─────────────────────────────── */
    .crop-overlay {
        position: fixed; inset: 0; z-index: 9000;
        background: rgba(0,0,0,.88);
        display: none;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }
    .crop-overlay.open { display: flex; }
    .crop-box {
        background: #1a1a1a;
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 14px;
        width: min(720px, 100%);
        max-height: calc(100dvh - 32px);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-shadow: 0 24px 80px rgba(0,0,0,.7);
    }
    .crop-header {
        display: flex; align-items: flex-start; justify-content: space-between;
        padding: 16px 20px 14px; border-bottom: 1px solid rgba(255,255,255,.08);
        flex-shrink: 0;
    }
    .crop-header-title { color: white; font-size: 15px; font-weight: 600; margin: 0 0 3px; }
    .crop-header-sub  { color: rgba(255,255,255,.3); font-size: 12px; }
    .crop-close {
        background: none; border: none;
        color: rgba(255,255,255,.35); font-size: 26px; line-height: 1;
        cursor: pointer; padding: 0 2px; margin-top: -2px;
        transition: color .15s;
    }
    .crop-close:hover { color: white; }
    .crop-body {
        flex: 1; overflow: hidden;
        background: #0a0a0a;
        min-height: 180px; max-height: 420px;
    }
    .crop-body > img { display: block; max-width: 100%; }
    .crop-footer {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 20px; border-top: 1px solid rgba(255,255,255,.08);
        flex-shrink: 0; gap: 10px;
    }
    .crop-footer-hint { color: rgba(255,255,255,.25); font-size: 11px; }
    .crop-footer-btns { display: flex; gap: 10px; }
    .btn-crop-cancel {
        background: transparent; border: 1px solid rgba(255,255,255,.15);
        color: rgba(255,255,255,.5); padding: 8px 18px;
        border-radius: 8px; font-size: 13px; cursor: pointer;
        transition: border-color .2s, color .2s;
    }
    .btn-crop-cancel:hover { border-color: rgba(255,255,255,.35); color: rgba(255,255,255,.8); }
    .btn-crop-confirm {
        background: #e63946; border: none; color: white;
        padding: 8px 22px; border-radius: 8px; font-size: 13px; font-weight: 600;
        cursor: pointer; transition: background .2s;
    }
    .btn-crop-confirm:hover { background: #c5303b; }
    .btn-crop-confirm:disabled { background: #7a1e26; cursor: default; }
</style>

<div class="edit-profile-wrap">
    <h1 class="edit-profile-title">Edit Profile</h1>

    <form method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <!-- Name -->
        <div class="form-group">
            <label class="form-label" for="Nome">Display Name</label>
            <input id="Nome" name="Nome" type="text" class="form-control-dark"
                   value="@Model.Nome" maxlength="100" placeholder="Your name" required />
            @if (ViewData.ModelState["Nome"]?.Errors.Count > 0)
            {
                <p class="field-error">@ViewData.ModelState["Nome"]!.Errors.First().ErrorMessage</p>
            }
        </div>

        <!-- Banner -->
        <div class="form-group">
            <label class="form-label">Banner Image
                <span style="font-weight:400;color:rgba(255,255,255,.25)">(4:1 — will be cropped automatically, up to 10 MB)</span>
            </label>
            <div class="banner-upload-zone @(!string.IsNullOrEmpty(Model.ImagemBannerAtual) ? "has-banner" : "")"
                 id="bannerZone" onclick="document.getElementById('bannerInput').click()">
                @if (!string.IsNullOrEmpty(Model.ImagemBannerAtual))
                {
                    <img class="preview" id="bannerPreview" src="@Model.ImagemBannerAtual" />
                }
                else
                {
                    <img class="preview" id="bannerPreview" src="" style="display:none" />
                }
                <div class="upload-hint" id="bannerHint" style="@(string.IsNullOrEmpty(Model.ImagemBannerAtual) ? "" : "display:none")">
                    <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/>
                    </svg>
                    <p>Click to choose a banner</p>
                </div>
                <span class="banner-re-crop" onclick="event.stopPropagation(); document.getElementById('bannerInput').click()">
                    Change / Recrop
                </span>
            </div>
            <input type="file" id="bannerInput" name="ImagemBanner" accept="image/*" />
            @if (!string.IsNullOrEmpty(ViewData.ModelState["ImagemBanner"]?.Errors.FirstOrDefault()?.ErrorMessage))
            {
                <p class="field-error">@ViewData.ModelState["ImagemBanner"]!.Errors.First().ErrorMessage</p>
            }
        </div>

        <!-- Avatar -->
        <div class="form-group">
            <label class="form-label">Profile Picture <span style="font-weight:400;color:rgba(255,255,255,.25)">(up to 5 MB)</span></label>
            <div class="avatar-row">
                <div class="avatar-upload-zone @(!string.IsNullOrEmpty(Model.FotoPerfilAtual) ? "has-image" : "")"
                     id="avatarZone" onclick="document.getElementById('avatarInput').click()">
                    @if (!string.IsNullOrEmpty(Model.FotoPerfilAtual))
                    {
                        <img class="preview" id="avatarPreview" src="@Model.FotoPerfilAtual" />
                    }
                    else
                    {
                        <img class="preview" id="avatarPreview" src="" style="display:none" />
                    }
                    <span class="avatar-placeholder">+</span>
                </div>
                <div class="avatar-info">
                    <strong>Profile picture</strong>
                    JPG, PNG, WEBP or GIF<br />
                    Maximum size: 5 MB
                </div>
            </div>
            <input type="file" id="avatarInput" name="FotoPerfil" accept="image/*" />
            @if (!string.IsNullOrEmpty(ViewData.ModelState["FotoPerfil"]?.Errors.FirstOrDefault()?.ErrorMessage))
            {
                <p class="field-error">@ViewData.ModelState["FotoPerfil"]!.Errors.First().ErrorMessage</p>
            }
        </div>

        <!-- Bio -->
        <div class="form-group">
            <label class="form-label" for="Sobre">About me</label>
            <textarea id="Sobre" name="Sobre" class="form-control-dark" maxlength="500"
                      placeholder="Tell us a bit about yourself…" oninput="updateCharCount(this)">@Model.Sobre</textarea>
            <p class="char-count" id="sobreCount">@((Model.Sobre ?? "").Length)/500</p>
        </div>

        <div class="btn-row">
            <a href="@Url.Action("Index", "Profile", new { id = Context.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value })" class="btn-cancel">Cancel</a>
            <button type="submit" class="btn-save">Save</button>
        </div>
    </form>
</div>

<!-- Crop modal (banner) -->
<div class="crop-overlay" id="cropOverlay">
    <div class="crop-box">
        <div class="crop-header">
            <div>
                <p class="crop-header-title">Adjust Banner</p>
                <p class="crop-header-sub">Drag to reposition · Use corners to resize</p>
            </div>
            <button class="crop-close" onclick="closeCrop()" aria-label="Fechar">&times;</button>
        </div>
        <div class="crop-body">
            <img id="cropImg" src="" alt="" />
        </div>
        <div class="crop-footer">
            <span class="crop-footer-hint">Fixed ratio 4:1 · Output 1200×300 px</span>
            <div class="crop-footer-btns">
                <button class="btn-crop-cancel" type="button" onclick="closeCrop()">Cancel</button>
                <button class="btn-crop-confirm" type="button" id="btnCropConfirm" onclick="confirmCrop()">Crop and Use</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
<script>
    var bannerCropper = null;

    // ── Banner input ──────────────────────────────
    document.getElementById('bannerInput').addEventListener('change', function () {
        if (!this.files || !this.files[0]) return;
        var reader = new FileReader();
        reader.onload = function (e) {
            var img = document.getElementById('cropImg');
            // Reset cropper before changing src
            if (bannerCropper) { bannerCropper.destroy(); bannerCropper = null; }
            img.src = e.target.result;
            document.getElementById('cropOverlay').classList.add('open');
            document.body.style.overflow = 'hidden';
        };
        reader.readAsDataURL(this.files[0]);
    });

    // Init cropper once image is loaded inside modal
    document.getElementById('cropImg').addEventListener('load', function () {
        if (!document.getElementById('cropOverlay').classList.contains('open')) return;
        if (bannerCropper) return; // already initialised
        bannerCropper = new Cropper(this, {
            aspectRatio: 4,
            viewMode: 1,
            dragMode: 'move',
            autoCropArea: 1,
            restore: false,
            guides: true,
            center: true,
            highlight: false,
            cropBoxMovable: true,
            cropBoxResizable: true,
            toggleDragModeOnDblclick: false,
            background: false
        });
    });

    function closeCrop() {
        document.getElementById('cropOverlay').classList.remove('open');
        document.body.style.overflow = '';
        if (bannerCropper) { bannerCropper.destroy(); bannerCropper = null; }
        document.getElementById('bannerInput').value = '';
    }

    function confirmCrop() {
        if (!bannerCropper) return;
        var btn = document.getElementById('btnCropConfirm');
        btn.disabled = true;
        btn.textContent = 'Processing…';

        bannerCropper.getCroppedCanvas({
            width: 1200,
            height: 300,
            imageSmoothingEnabled: true,
            imageSmoothingQuality: 'high'
        }).toBlob(function (blob) {
            // Replace file input with cropped blob
            var file = new File([blob], 'banner.jpg', { type: 'image/jpeg' });
            var dt = new DataTransfer();
            dt.items.add(file);
            document.getElementById('bannerInput').files = dt.files;

            // Update preview zone
            var url = URL.createObjectURL(blob);
            var preview = document.getElementById('bannerPreview');
            preview.src = url;
            preview.style.display = '';
            document.getElementById('bannerHint').style.display = 'none';
            document.getElementById('bannerZone').classList.add('has-banner');

            // Close modal
            document.getElementById('cropOverlay').classList.remove('open');
            document.body.style.overflow = '';
            bannerCropper.destroy();
            bannerCropper = null;
            btn.disabled = false;
            btn.textContent = 'Crop and Use';
        }, 'image/jpeg', 0.92);
    }

    // ── Avatar input (direct preview, no crop) ────
    document.getElementById('avatarInput').addEventListener('change', function () {
        if (!this.files || !this.files[0]) return;
        var reader = new FileReader();
        reader.onload = function (e) {
            var preview = document.getElementById('avatarPreview');
            preview.src = e.target.result;
            preview.style.display = '';
            document.getElementById('avatarZone').classList.add('has-image');
        };
        reader.readAsDataURL(this.files[0]);
    });

    // ── Bio char count ────────────────────────────
    function updateCharCount(textarea) {
        var len = textarea.value.length;
        var el = document.getElementById('sobreCount');
        el.textContent = len + '/500';
        el.className = 'char-count' + (len > 480 ? ' near' : '') + (len >= 500 ? ' over' : '');
    }
</script>
}
