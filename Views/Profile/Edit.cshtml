@model AnyComic.Models.ViewModels.EditarPerfilViewModel
@{
    ViewData["Title"] = "Editar Perfil";
}

<style>
    .edit-profile-wrap {
        max-width: 680px;
        margin: 36px auto 60px;
        padding: 0 16px;
    }
    .edit-profile-title {
        font-size: 20px;
        font-weight: 700;
        color: white;
        margin-bottom: 28px;
    }

    /* Banner upload */
    .banner-upload-zone {
        width: 100%;
        height: 160px;
        border-radius: 12px;
        border: 2px dashed rgba(255,255,255,.15);
        background: #1a1a1a;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        overflow: hidden;
        position: relative;
        transition: border-color .2s;
        margin-bottom: 24px;
    }
    .banner-upload-zone:hover { border-color: #e63946; }
    .banner-upload-zone .upload-hint {
        text-align: center;
        color: rgba(255,255,255,.3);
        pointer-events: none;
    }
    .banner-upload-zone .upload-hint svg { display: block; margin: 0 auto 8px; }
    .banner-upload-zone .upload-hint p { font-size: 13px; margin: 0; }
    .banner-upload-zone img.preview {
        position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    }

    /* Avatar upload */
    .avatar-row { display: flex; align-items: center; gap: 20px; margin-bottom: 24px; }
    .avatar-upload-zone {
        width: 88px; height: 88px;
        border-radius: 50%;
        border: 2px dashed rgba(255,255,255,.2);
        background: #2a2a2a;
        display: flex; align-items: center; justify-content: center;
        cursor: pointer; overflow: hidden; position: relative;
        flex-shrink: 0; transition: border-color .2s;
    }
    .avatar-upload-zone:hover { border-color: #e63946; }
    .avatar-upload-zone img.preview {
        position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover;
    }
    .avatar-upload-zone .avatar-placeholder {
        font-size: 28px; font-weight: 700; color: rgba(255,255,255,.35); pointer-events: none;
    }
    .avatar-upload-zone.has-image .avatar-placeholder { display: none; }
    .avatar-info { color: rgba(255,255,255,.4); font-size: 12px; line-height: 1.6; }
    .avatar-info strong { color: rgba(255,255,255,.7); display: block; font-size: 14px; margin-bottom: 2px; }

    /* Form elements */
    .form-group { margin-bottom: 22px; }
    .form-label { display: block; font-size: 13px; font-weight: 600; color: rgba(255,255,255,.55); margin-bottom: 8px; }
    .form-control-dark {
        width: 100%;
        background: #1a1a1a;
        border: 1px solid rgba(255,255,255,.1);
        border-radius: 8px;
        color: white;
        padding: 11px 14px;
        font-size: 14px;
        resize: vertical;
        font-family: inherit;
        transition: border-color .2s;
    }
    .form-control-dark:focus { outline: none; border-color: #e63946; }
    .form-control-dark::placeholder { color: rgba(255,255,255,.2); }
    textarea.form-control-dark { min-height: 110px; }

    .char-count { font-size: 11px; color: rgba(255,255,255,.25); text-align: right; margin-top: 4px; }
    .char-count.near { color: #e69346; }
    .char-count.over  { color: #e63946; }

    .field-error { color: #e63946; font-size: 12px; margin-top: 4px; }

    /* Buttons */
    .btn-row { display: flex; gap: 12px; justify-content: flex-end; margin-top: 32px; }
    .btn-save {
        background: #e63946; color: white; border: none;
        padding: 10px 28px; border-radius: 8px; font-size: 14px; font-weight: 600;
        cursor: pointer; transition: background .2s;
    }
    .btn-save:hover { background: #c5303b; }
    .btn-cancel {
        background: transparent; color: rgba(255,255,255,.5);
        border: 1px solid rgba(255,255,255,.15);
        padding: 10px 20px; border-radius: 8px; font-size: 14px;
        text-decoration: none; transition: border-color .2s, color .2s;
    }
    .btn-cancel:hover { border-color: rgba(255,255,255,.35); color: rgba(255,255,255,.8); }

    input[type=file] { display: none; }
</style>

<div class="edit-profile-wrap">
    <h1 class="edit-profile-title">Editar Perfil</h1>

    <form method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()

        <!-- Banner -->
        <div class="form-group">
            <label class="form-label">Imagem de Banner <span style="font-weight:400;color:rgba(255,255,255,.25)">(recomendado 1200×300, até 10 MB)</span></label>
            <div class="banner-upload-zone" id="bannerZone" onclick="document.getElementById('bannerInput').click()">
                @if (!string.IsNullOrEmpty(Model.ImagemBannerAtual))
                {
                    <img class="preview" id="bannerPreview" src="@Model.ImagemBannerAtual" />
                }
                else
                {
                    <img class="preview" id="bannerPreview" src="" style="display:none" />
                }
                <div class="upload-hint" id="bannerHint" style="@(string.IsNullOrEmpty(Model.ImagemBannerAtual) ? "" : "display:none")">
                    <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/>
                    </svg>
                    <p>Clique para escolher o banner</p>
                </div>
            </div>
            <input type="file" id="bannerInput" name="ImagemBanner" accept="image/*" onchange="previewImage(this,'bannerPreview','bannerHint')" />
            @if (!string.IsNullOrEmpty(ViewData.ModelState["ImagemBanner"]?.Errors.FirstOrDefault()?.ErrorMessage))
            {
                <p class="field-error">@ViewData.ModelState["ImagemBanner"]!.Errors.First().ErrorMessage</p>
            }
        </div>

        <!-- Avatar -->
        <div class="form-group">
            <label class="form-label">Foto de Perfil <span style="font-weight:400;color:rgba(255,255,255,.25)">(até 5 MB)</span></label>
            <div class="avatar-row">
                <div class="avatar-upload-zone @(!string.IsNullOrEmpty(Model.FotoPerfilAtual) ? "has-image" : "")"
                     id="avatarZone" onclick="document.getElementById('avatarInput').click()">
                    @if (!string.IsNullOrEmpty(Model.FotoPerfilAtual))
                    {
                        <img class="preview" id="avatarPreview" src="@Model.FotoPerfilAtual" />
                    }
                    else
                    {
                        <img class="preview" id="avatarPreview" src="" style="display:none" />
                    }
                    <span class="avatar-placeholder">+</span>
                </div>
                <div class="avatar-info">
                    <strong>Foto de perfil</strong>
                    JPG, PNG, WEBP ou GIF<br />
                    Tamanho máximo: 5 MB
                </div>
            </div>
            <input type="file" id="avatarInput" name="FotoPerfil" accept="image/*" onchange="previewImage(this,'avatarPreview','',true)" />
            @if (!string.IsNullOrEmpty(ViewData.ModelState["FotoPerfil"]?.Errors.FirstOrDefault()?.ErrorMessage))
            {
                <p class="field-error">@ViewData.ModelState["FotoPerfil"]!.Errors.First().ErrorMessage</p>
            }
        </div>

        <!-- Bio -->
        <div class="form-group">
            <label class="form-label" for="Sobre">Sobre mim</label>
            <textarea id="Sobre" name="Sobre" class="form-control-dark" maxlength="500"
                      placeholder="Fale um pouco sobre você…" oninput="updateCharCount(this)">@Model.Sobre</textarea>
            <p class="char-count" id="sobreCount">
                @((Model.Sobre ?? "").Length)/500
            </p>
        </div>

        <div class="btn-row">
            <a href="@Url.Action("Index", "Profile", new { id = Context.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value })" class="btn-cancel">Cancelar</a>
            <button type="submit" class="btn-save">Salvar</button>
        </div>
    </form>
</div>

@section Scripts {
<script>
    function previewImage(input, previewId, hintId, isAvatar) {
        if (!input.files || !input.files[0]) return;
        var reader = new FileReader();
        reader.onload = function (e) {
            var preview = document.getElementById(previewId);
            preview.src = e.target.result;
            preview.style.display = '';
            if (hintId) {
                var hint = document.getElementById(hintId);
                if (hint) hint.style.display = 'none';
            }
            if (isAvatar) {
                document.getElementById('avatarZone').classList.add('has-image');
            }
        };
        reader.readAsDataURL(input.files[0]);
    }

    function updateCharCount(textarea) {
        var len = textarea.value.length;
        var el = document.getElementById('sobreCount');
        el.textContent = len + '/500';
        el.className = 'char-count' + (len > 480 ? ' near' : '') + (len >= 500 ? ' over' : '');
    }
</script>
}
