@model AnyComic.Models.ViewModels.PerfilViewModel
@{
    ViewData["Title"] = Model.Usuario.Nome;
    var avatarUrl = string.IsNullOrEmpty(Model.Usuario.FotoPerfil) ? null : Model.Usuario.FotoPerfil;
    var bannerUrl = string.IsNullOrEmpty(Model.Usuario.ImagemBanner) ? null : Model.Usuario.ImagemBanner;
    var inicial = Model.Usuario.Nome.Length > 0 ? Model.Usuario.Nome[0].ToString().ToUpper() : "?";
}

<style>
    .profile-wrap { max-width: 1100px; margin: 0 auto; padding: 0 0 60px; }

    /* Banner */
    .profile-banner {
        height: 220px;
        background-color: #1a1a1a;
        background-size: cover;
        background-position: center;
        position: relative;
    }
    .profile-banner::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,.65) 100%);
    }
    .profile-banner.no-banner {
        background: linear-gradient(135deg, #1a1a1a 0%, #2a1a1a 50%, #1a0a0a 100%);
        border-bottom: 2px solid #e63946;
    }

    /* Header row */
    .profile-head {
        display: flex;
        align-items: flex-end;
        gap: 20px;
        padding: 0 24px;
        margin-top: -52px;
        position: relative;
        z-index: 2;
    }
    .profile-avatar {
        width: 104px;
        height: 104px;
        border-radius: 50%;
        border: 4px solid #0f0f0f;
        object-fit: cover;
        flex-shrink: 0;
        background: #2a2a2a;
    }
    .profile-avatar-placeholder {
        width: 104px;
        height: 104px;
        border-radius: 50%;
        border: 4px solid #0f0f0f;
        background: #e63946;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        font-weight: 700;
        color: white;
        flex-shrink: 0;
    }
    .profile-name-block {
        flex: 1;
        padding-bottom: 8px;
        min-width: 0;
    }
    .profile-name {
        font-size: 22px;
        font-weight: 700;
        color: white;
        margin: 0 0 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .profile-joined {
        font-size: 13px;
        color: rgba(255,255,255,.45);
    }
    .btn-edit-profile {
        flex-shrink: 0;
        background: transparent;
        border: 1px solid rgba(255,255,255,.25);
        color: rgba(255,255,255,.75);
        padding: 7px 18px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        transition: border-color .2s, color .2s;
        margin-bottom: 8px;
    }
    .btn-edit-profile:hover { border-color: #e63946; color: #e63946; }

    /* About */
    .profile-about {
        margin: 24px 24px 0;
        background: #1a1a1a;
        border-radius: 10px;
        padding: 18px 20px;
        border: 1px solid rgba(255,255,255,.07);
    }
    .profile-about h3 {
        font-size: 13px;
        font-weight: 600;
        color: rgba(255,255,255,.4);
        text-transform: uppercase;
        letter-spacing: .8px;
        margin-bottom: 10px;
    }
    .profile-about p {
        font-size: 14px;
        color: rgba(255,255,255,.8);
        line-height: 1.65;
        white-space: pre-wrap;
        margin: 0;
    }

    /* Sections */
    .profile-section { margin: 28px 24px 0; }
    .profile-section-title {
        font-size: 15px;
        font-weight: 600;
        color: rgba(255,255,255,.6);
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .profile-section-title span.count {
        font-size: 12px;
        background: rgba(255,255,255,.08);
        border-radius: 20px;
        padding: 2px 9px;
        color: rgba(255,255,255,.4);
    }

    /* Media grid */
    .profile-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
        gap: 12px;
    }
    .profile-card {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        border-radius: 8px;
        overflow: hidden;
        background: #1a1a1a;
        border: 1px solid rgba(255,255,255,.06);
        transition: transform .2s, border-color .2s;
    }
    .profile-card:hover { transform: translateY(-3px); border-color: rgba(230,57,70,.4); }
    .profile-card img {
        width: 100%;
        aspect-ratio: 2/3;
        object-fit: cover;
        display: block;
    }
    .profile-card .card-title {
        padding: 6px 8px;
        font-size: 11px;
        color: rgba(255,255,255,.7);
        line-height: 1.3;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .profile-empty {
        color: rgba(255,255,255,.25);
        font-size: 13px;
        padding: 12px 0;
    }

    @@media (max-width: 600px) {
        /* Header: avatar + edit btn on row 1, name on row 2 */
        .profile-head {
            flex-wrap: wrap;
            align-items: flex-start;
            gap: 0;
            padding: 0 14px;
        }
        .btn-edit-profile {
            order: 2;
            margin-left: auto;
            align-self: flex-end;
            margin-bottom: 6px;
        }
        .profile-name-block {
            order: 3;
            flex: 0 0 100%;
            padding: 10px 0 4px;
        }
        .profile-name {
            font-size: 19px;
            white-space: normal;
        }
        /* Smaller cards on mobile */
        .profile-grid {
            grid-template-columns: repeat(auto-fill, minmax(88px, 1fr));
            gap: 8px;
        }
        .profile-card .card-title { font-size: 10px; padding: 5px 6px; }
        .profile-about, .profile-section { margin-left: 14px; margin-right: 14px; }
    }
</style>

<!-- Banner -->
<div class="profile-wrap">
    <div class="profile-banner @(bannerUrl == null ? "no-banner" : "")"
         @if (bannerUrl != null) { <text>style="background-image:url('@bannerUrl')"</text> }>
    </div>

    <!-- Head: avatar + name + edit btn -->
    <div class="profile-head">
        @if (avatarUrl != null)
        {
            <img class="profile-avatar" src="@avatarUrl" alt="@Model.Usuario.Nome" />
        }
        else
        {
            <div class="profile-avatar-placeholder">@inicial</div>
        }

        <div class="profile-name-block">
            <h1 class="profile-name">@Model.Usuario.Nome</h1>
            <span class="profile-joined">Membro desde @Model.Usuario.DataCriacao.ToString("MMM yyyy")</span>
        </div>

        @if (Model.IsOwnProfile)
        {
            <a href="/Profile/Edit" class="btn-edit-profile">Editar Perfil</a>
        }
    </div>

    <!-- About -->
    @if (!string.IsNullOrWhiteSpace(Model.Usuario.Sobre))
    {
        <div class="profile-about">
            <h3>Sobre</h3>
            <p>@Model.Usuario.Sobre</p>
        </div>
    }

    <!-- Manga Favorites -->
    <div class="profile-section">
        <p class="profile-section-title">
            Mangás Favoritos
            <span class="count">@Model.FavoritosManga.Count</span>
        </p>
        @if (Model.FavoritosManga.Any())
        {
            <div class="profile-grid">
                @foreach (var fav in Model.FavoritosManga)
                {
                    <a href="@Url.Action("Details", "Manga", new { id = fav.MangaId })" class="profile-card">
                        <img src="@fav.Manga!.ImagemCapa" alt="@fav.Manga.Titulo" loading="lazy" />
                        <span class="card-title">@fav.Manga.Titulo</span>
                    </a>
                }
            </div>
        }
        else
        {
            <p class="profile-empty">Nenhum mangá favorito ainda.</p>
        }
    </div>

    <!-- Anime Favorites -->
    <div class="profile-section">
        <p class="profile-section-title">
            Animes Favoritos
            <span class="count">@Model.FavoritosAnime.Count</span>
        </p>
        @if (Model.FavoritosAnime.Any())
        {
            <div class="profile-grid">
                @foreach (var fav in Model.FavoritosAnime)
                {
                    <a href="@Url.Action("Details", "Anime", new { id = fav.AnimeId })" class="profile-card">
                        <img src="@fav.Anime!.ImagemCapa" alt="@fav.Anime.Titulo" loading="lazy" />
                        <span class="card-title">@fav.Anime.Titulo</span>
                    </a>
                }
            </div>
        }
        else
        {
            <p class="profile-empty">Nenhum anime favorito ainda.</p>
        }
    </div>
</div>
